generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////////////////
// AUTH
////////////////////////////////

model User {
  id                 Int              @id @default(autoincrement())
  nombre             String
  email              String           @unique
  password           String
  role               ExploRole        @default(GEOLOGO)
  activo             Boolean          @default(true)
  createdAt          DateTime         @default(now())
  resetToken         String?
  resetTokenExpiry   DateTime?
  refreshToken       String?
  refreshTokenExpiry DateTime?
  interiorSamples    InteriorSample[]        @relation("InteriorSampleCreatedBy")
  surfaceSamples     SurfaceSample[]         @relation("SurfaceSampleCreatedBy")
  interiorDispatches InteriorSampleDispatch[] @relation("InteriorDispatchCreatedBy")
  surfaceDispatches  SurfaceSampleDispatch[]  @relation("SurfaceDispatchCreatedBy")
}

////////////////////////////////
// EXPLORACIÓN DE SONDAJES (DRILLING)
////////////////////////////////

model Project {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  location    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  createdById Int?
  updatedById Int?
  drillHoles  DrillHole[]
  resources   Resource[]
  zones       Zone[]
}

model Zone {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  projectId   Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  createdById Int?
  updatedById Int?
  drillHoles  DrillHole[]
  project     Project     @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model DrillHole {
  id                    Int                   @id @default(autoincrement())
  name                  String
  projectId             Int
  zoneId                Int
  east                  Decimal               @db.Decimal(12, 4)
  north                 Decimal               @db.Decimal(12, 4)
  elevation             Decimal?              @db.Decimal(12, 4)
  depth                 Decimal               @db.Decimal(12, 4)
  azimuth               Decimal?              @db.Decimal(9, 4)
  dip                   Decimal?              @db.Decimal(9, 4)
  type                  DrillHoleType
  campaign              String?
  year                  Int?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  createdById           Int?
  updatedById           Int?
  project               Project               @relation(fields: [projectId], references: [id])
  zone                  Zone                  @relation(fields: [zoneId], references: [id])
  drillHoleSurveys      DrillHoleSurvey[]
  intervals             Interval[]
  significantIntercepts SignificantIntercept[]

  @@index([east, north])
  @@index([projectId])
  @@index([zoneId])
}

model DrillHoleSurvey {
  id          Int        @id @default(autoincrement())
  drillHoleId Int?
  depth       Decimal    @db.Decimal(12, 4)
  azimuth     Decimal    @db.Decimal(9, 4)
  dip         Decimal    @db.Decimal(9, 4)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  createdById Int?
  updatedById Int?
  drillHole   DrillHole? @relation(fields: [drillHoleId], references: [id])

  @@index([drillHoleId])
}

model Interval {
  id                       Int                      @id @default(autoincrement())
  drillHoleId              Int
  fromDepth                Decimal                  @db.Decimal(12, 4)
  toDepth                  Decimal                  @db.Decimal(12, 4)
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  createdById              Int?
  updatedById              Int?
  alterations              Alteration[]
  assays                   Assay[]
  densities                Density[]
  geologicalStructures     GeologicalStructure[]
  drillHole                DrillHole                @relation(fields: [drillHoleId], references: [id])
  lithologies              Lithology[]
  magneticSusceptibilities MagneticSusceptibility[]
  mineralizations          Mineralization[]
  recoveries               Recovery[]

  @@index([drillHoleId])
}

model Assay {
  id          Int          @id @default(autoincrement())
  intervalId  Int
  au          Decimal      @db.Decimal(12, 4)
  cu          Decimal      @db.Decimal(12, 4)
  ag          Decimal      @db.Decimal(12, 4)
  assayMethod AssayMethod
  laboratory  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdById Int?
  updatedById Int?
  interval    Interval     @relation(fields: [intervalId], references: [id])
  assayValues AssayValue[]
  qaqcRecords QAQC[]

  @@index([intervalId])
}

model AssayValue {
  id             Int      @id @default(autoincrement())
  assayId        Int?
  element        String
  value          Decimal  @db.Decimal(18, 6)
  unit           String?
  detectionLimit Decimal? @db.Decimal(18, 6)
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  createdById    Int?
  updatedById    Int?
  assay          Assay?   @relation(fields: [assayId], references: [id])

  @@index([assayId])
  @@index([element])
}

model QAQC {
  id          Int      @id @default(autoincrement())
  assayId     Int
  type        QAQCType
  passed      Boolean
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById Int?
  updatedById Int?
  assay       Assay    @relation(fields: [assayId], references: [id])

  @@index([assayId])
}

model Lithology {
  id          Int      @id @default(autoincrement())
  intervalId  Int
  rockType    String?
  code        String?
  color       String?
  grainSize   String?
  texture     String?
  weathering  String?
  comments    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById Int?
  updatedById Int?
  interval    Interval @relation(fields: [intervalId], references: [id])

  @@index([intervalId])
}

model Alteration {
  id          Int       @id @default(autoincrement())
  intervalId  Int?
  type        String
  intensity   Decimal?  @db.Decimal(5, 2)
  description String?
  comments    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  createdById Int?
  updatedById Int?
  interval    Interval? @relation(fields: [intervalId], references: [id])

  @@index([intervalId])
}

model Mineralization {
  id          Int       @id @default(autoincrement())
  intervalId  Int?
  mineral     String
  percentage  Decimal?  @db.Decimal(5, 2)
  style       String?
  habit       String?
  description String?
  comments    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  createdById Int?
  updatedById Int?
  interval    Interval? @relation(fields: [intervalId], references: [id])

  @@index([intervalId])
}

model GeologicalStructure {
  id            Int       @id @default(autoincrement())
  intervalId    Int?
  structureType String
  angle         Decimal?  @db.Decimal(9, 4)
  width         Decimal?  @db.Decimal(12, 4)
  orientation   String?
  description   String?
  comments      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  createdById   Int?
  updatedById   Int?
  interval      Interval? @relation(fields: [intervalId], references: [id])

  @@index([intervalId])
}

model Recovery {
  id              Int       @id @default(autoincrement())
  intervalId      Int?
  recoveryPercent Decimal?  @db.Decimal(5, 2)
  rqdPercent      Decimal?  @db.Decimal(5, 2)
  coreLoss        Decimal?  @db.Decimal(12, 4)
  comments        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
  createdById     Int?
  updatedById     Int?
  interval        Interval? @relation(fields: [intervalId], references: [id])

  @@index([intervalId])
}

model Density {
  id              Int       @id @default(autoincrement())
  intervalId      Int?
  specificGravity Decimal   @db.Decimal(8, 4)
  method          String?
  dryDensity      Decimal?  @db.Decimal(8, 4)
  wetDensity      Decimal?  @db.Decimal(8, 4)
  comments        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
  createdById     Int?
  updatedById     Int?
  interval        Interval? @relation(fields: [intervalId], references: [id])

  @@index([intervalId])
}

model MagneticSusceptibility {
  id          Int       @id @default(autoincrement())
  intervalId  Int?
  value       Decimal   @db.Decimal(18, 6)
  unit        String?
  instrument  String?
  comments    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  createdById Int?
  updatedById Int?
  interval    Interval? @relation(fields: [intervalId], references: [id])

  @@index([intervalId])
}

model Resource {
  id          Int              @id @default(autoincrement())
  projectId   Int
  type        ResourceType
  category    ResourceCategory
  cutoff      Decimal          @db.Decimal(12, 4)
  tonnes      Decimal          @db.Decimal(18, 2)
  au          Decimal          @db.Decimal(12, 4)
  cu          Decimal          @db.Decimal(12, 4)
  ag          Decimal          @db.Decimal(12, 4)
  cuEq        Decimal          @db.Decimal(12, 4)
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  createdById Int?
  updatedById Int?
  project     Project          @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model SignificantIntercept {
  id          Int       @id @default(autoincrement())
  drillHoleId Int
  isIncluding Boolean   @default(false)
  fromDepth   Decimal   @db.Decimal(12, 4)
  toDepth     Decimal   @db.Decimal(12, 4)
  width       Decimal   @db.Decimal(12, 4)
  trueWidth   Decimal?  @db.Decimal(12, 4)
  au          Decimal?  @db.Decimal(12, 4)
  cu          Decimal?  @db.Decimal(12, 4)
  ag          Decimal?  @db.Decimal(12, 4)
  comments    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  createdById Int?
  updatedById Int?
  drillHole   DrillHole @relation(fields: [drillHoleId], references: [id])

  @@index([drillHoleId])
}

////////////////////////////////
// EXPLORACIÓN SUPERFICIAL / CANALES
////////////////////////////////

model MiningArea {
  id           String        @id @default(uuid())
  name         String
  abbreviation String?
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  createdById  Int?
  updatedById  Int?
  levels       MiningLevel[]
}

model MiningLevel {
  id           String        @id @default(uuid())
  miningAreaId String
  name         String
  abbreviation String?
  elevation    Float?
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  createdById  Int?
  updatedById  Int?
  miningArea   MiningArea    @relation(fields: [miningAreaId], references: [id])
  labors       MiningLabor[]

  @@index([miningAreaId])
}

model MiningLabor {
  id            String      @id @default(uuid())
  miningLevelId String
  name          String
  abbreviation  String?
  code          String?
  description   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  createdById   Int?
  updatedById   Int?
  miningLevel   MiningLevel @relation(fields: [miningLevelId], references: [id])
  samples       Sample[]

  @@index([miningLevelId])
}

model Sample {
  id             String             @id @default(uuid())
  miningLaborId  String
  number         Int?
  sampledAt      DateTime?
  name           String?
  sampleType     SampleType?
  code           String             @unique
  placeReference String?
  east           Float?
  north          Float?
  elevation      Float?
  description    String?
  observations   String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  createdById    Int?
  updatedById    Int?
  miningLabor    MiningLabor        @relation(fields: [miningLaborId], references: [id])
  sampleLabs     SampleLaboratory[]
  results        SampleResult[]
  qaqcRecords    SampleQAQC[]

  @@index([miningLaborId])
  @@index([code])
  @@index([east, north])
}

model Laboratory {
  id           String             @id @default(uuid())
  name         String             @unique
  abbreviation String?
  description  String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  createdById  Int?
  updatedById  Int?
  sampleLabs   SampleLaboratory[]
}

model SampleLaboratory {
  id           String         @id @default(uuid())
  sampleId     String
  laboratoryId String
  slot         LaboratorySlot
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  createdById  Int?
  updatedById  Int?
  sample       Sample         @relation(fields: [sampleId], references: [id])
  laboratory   Laboratory     @relation(fields: [laboratoryId], references: [id])
  results      SampleResult[]

  @@unique([sampleId, slot])
  @@index([sampleId])
  @@index([laboratoryId])
}

model Element {
  id              String                 @id @default(uuid())
  name            String
  symbol          String
  defaultUnit     String?
  description     String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  createdById     Int?
  updatedById     Int?
  results                  SampleResult[]
  interiorResults          InteriorSampleResult[]
  surfaceResults           SurfaceSampleResult[]
  interiorDispatchElements InteriorDispatchElement[]
  surfaceDispatchElements  SurfaceDispatchElement[]

  @@unique([symbol, defaultUnit])
  @@index([symbol])
}

model SampleResult {
  id                 String            @id @default(uuid())
  sampleId           String
  sampleLaboratoryId String?
  elementId          String
  value              Float?
  qualifier          String?
  unit               String?
  sourceColumn       String?
  comments           String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  createdById        Int?
  updatedById        Int?
  sample             Sample            @relation(fields: [sampleId], references: [id])
  sampleLaboratory   SampleLaboratory? @relation(fields: [sampleLaboratoryId], references: [id])
  element            Element           @relation(fields: [elementId], references: [id])

  @@unique([sampleId, sampleLaboratoryId, elementId, unit, sourceColumn])
  @@index([sampleId])
  @@index([sampleLaboratoryId])
  @@index([elementId])
}

model SampleQAQC {
  id               String   @id @default(uuid())
  sampleId         String
  type             String
  passed           Boolean?
  expectedValue    Float?
  obtainedValue    Float?
  deviationPercent Float?
  comments         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  createdById      Int?
  updatedById      Int?
  sample           Sample   @relation(fields: [sampleId], references: [id])

  @@index([sampleId])
}

////////////////////////////////
// INTERIOR MINA - PROPUESTA DE MUESTRAS
////////////////////////////////

model InteriorArea {
  id           String          @id @default(uuid())
  name         String
  abbreviation String          @unique
  description  String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  createdById  Int?
  updatedById  Int?
  levels       InteriorLevel[]
}

model InteriorLevel {
  id             String           @id @default(uuid())
  interiorAreaId String
  name           String
  abbreviation   String
  codeStart      Int              @default(1)
  elevation      Float?
  description    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  createdById    Int?
  updatedById    Int?
  area           InteriorArea     @relation(fields: [interiorAreaId], references: [id])
  labors         InteriorLabor[]
  samples        InteriorSample[] @relation("InteriorSampleLevel")

  @@unique([interiorAreaId, abbreviation])
  @@index([interiorAreaId])
}

model InteriorLabor {
  id              String           @id @default(uuid())
  interiorLevelId String
  name            String
  abbreviation    String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdById     Int?
  updatedById     Int?
  level           InteriorLevel    @relation(fields: [interiorLevelId], references: [id])
  samples         InteriorSample[]

  @@unique([interiorLevelId, abbreviation])
  @@index([interiorLevelId])
}

model InteriorObjective {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  createdById Int?
  updatedById Int?
  samples     InteriorSample[]
}

model InteriorLaboratory {
  id           String                  @id @default(uuid())
  name         String                  @unique
  abbreviation String?
  description  String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  createdById  Int?
  updatedById  Int?
  assignments  InteriorLabAssignment[]
  dispatches   InteriorSampleDispatch[]
}

model InteriorSample {
  id                  String                  @id @default(uuid())
  interiorLaborId     String
  interiorLevelId     String
  interiorObjectiveId String
  name                String?
  code                String                  @unique
  sequentialNumber    Int
  priority            SamplePriority          @default(NORMAL)
  category            SampleCategory          @default(EXPLORATION)
  status              SampleStatus            @default(REGISTERED)
  east                Float?
  north               Float?
  elevation           Float?
  sampledAt           DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  createdById         Int?
  updatedById         Int?
  labor               InteriorLabor           @relation(fields: [interiorLaborId], references: [id])
  level               InteriorLevel           @relation("InteriorSampleLevel", fields: [interiorLevelId], references: [id])
  objective           InteriorObjective       @relation(fields: [interiorObjectiveId], references: [id])
  createdBy           User?                   @relation("InteriorSampleCreatedBy", fields: [createdById], references: [id])
  labAssignments      InteriorLabAssignment[]
  results             InteriorSampleResult[]  @relation("InteriorSampleToResults")
  dispatchItems       InteriorDispatchItem[]

  @@index([interiorLaborId])
  @@index([interiorLevelId])
  @@index([interiorObjectiveId])
  @@index([priority])
  @@index([category])
  @@index([status])
  @@index([east, north])
}

model InteriorLabAssignment {
  id                   String                  @id @default(uuid())
  interiorSampleId     String
  interiorLaboratoryId String
  slot                 String
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  createdById          Int?
  updatedById          Int?
  sample               InteriorSample          @relation(fields: [interiorSampleId], references: [id])
  laboratory           InteriorLaboratory      @relation(fields: [interiorLaboratoryId], references: [id])
  results              InteriorSampleResult[]

  @@unique([interiorSampleId, slot])
  @@index([interiorSampleId])
  @@index([interiorLaboratoryId])
}

model InteriorSampleResult {
  id                      String                @id @default(uuid())
  interiorSampleId        String
  interiorLabAssignmentId String
  elementId               String
  value                   Float?
  unit                    String?
  qualifier               String?
  comments                String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  createdById             Int?
  updatedById             Int?
  sample                  InteriorSample        @relation("InteriorSampleToResults", fields: [interiorSampleId], references: [id])
  assignment              InteriorLabAssignment @relation(fields: [interiorLabAssignmentId], references: [id])
  element                 Element               @relation(fields: [elementId], references: [id])

  @@unique([interiorLabAssignmentId, elementId])
  @@index([interiorSampleId])
  @@index([interiorLabAssignmentId])
  @@index([elementId])
}

model InteriorSampleDispatch {
  id                   String                  @id @default(uuid())
  interiorLaboratoryId String
  projectName          String?
  sentAt               DateTime
  notes                String?
  status               DispatchStatus          @default(PENDING)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  createdById          Int?
  updatedById          Int?
  laboratory           InteriorLaboratory      @relation(fields: [interiorLaboratoryId], references: [id])
  createdBy            User?                   @relation("InteriorDispatchCreatedBy", fields: [createdById], references: [id])
  items                InteriorDispatchItem[]

  @@index([interiorLaboratoryId])
  @@index([status])
}

model InteriorDispatchItem {
  id                String                    @id @default(uuid())
  dispatchId        String
  interiorSampleId  String
  status            DispatchStatus            @default(PENDING)
  notes             String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  createdById       Int?
  updatedById       Int?
  dispatch          InteriorSampleDispatch    @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  sample            InteriorSample            @relation(fields: [interiorSampleId], references: [id], onDelete: Cascade)
  requestedElements InteriorDispatchElement[]

  @@unique([dispatchId, interiorSampleId])
  @@index([dispatchId])
  @@index([interiorSampleId])
  @@index([status])
}

model InteriorDispatchElement {
  id             String               @id @default(uuid())
  dispatchItemId String
  elementId      String
  dispatchItem   InteriorDispatchItem @relation(fields: [dispatchItemId], references: [id], onDelete: Cascade)
  element        Element              @relation(fields: [elementId], references: [id])

  @@unique([dispatchItemId, elementId])
  @@index([dispatchItemId])
  @@index([elementId])
}

////////////////////////////////
// SUPERFICIE - PROPUESTA DE MUESTRAS
////////////////////////////////

model SurfaceArea {
  id           String          @id @default(uuid())
  name         String
  abbreviation String          @unique
  description  String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  createdById  Int?
  updatedById  Int?
  samples      SurfaceSample[]
}

model SurfaceObjective {
  id          String          @id @default(uuid())
  name        String          @unique
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdById Int?
  updatedById Int?
  samples     SurfaceSample[]
}

model SurfaceLaboratory {
  id           String                  @id @default(uuid())
  name         String                  @unique
  abbreviation String?
  description  String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  createdById  Int?
  updatedById  Int?
  assignments  SurfaceLabAssignment[]
  dispatches   SurfaceSampleDispatch[]
}

model SurfaceSample {
  id                 String                 @id @default(uuid())
  surfaceAreaId      String
  surfaceObjectiveId String
  name               String?
  code               String                 @unique
  sequentialNumber   Int
  priority           SamplePriority         @default(NORMAL)
  category           SampleCategory         @default(EXPLORATION)
  status             SampleStatus           @default(REGISTERED)
  east               Float?
  north              Float?
  elevation          Float?
  sampledAt          DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  createdById        Int?
  updatedById        Int?
  area               SurfaceArea            @relation(fields: [surfaceAreaId], references: [id])
  objective          SurfaceObjective       @relation(fields: [surfaceObjectiveId], references: [id])
  createdBy          User?                  @relation("SurfaceSampleCreatedBy", fields: [createdById], references: [id])
  labAssignments     SurfaceLabAssignment[]
  results            SurfaceSampleResult[]
  dispatchItems      SurfaceDispatchItem[]

  @@index([surfaceAreaId])
  @@index([surfaceObjectiveId])
  @@index([priority])
  @@index([category])
  @@index([status])
  @@index([east, north])
}

model SurfaceLabAssignment {
  id                  String                @id @default(uuid())
  surfaceSampleId     String
  surfaceLaboratoryId String
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  createdById         Int?
  updatedById         Int?
  sample              SurfaceSample         @relation(fields: [surfaceSampleId], references: [id])
  laboratory          SurfaceLaboratory     @relation(fields: [surfaceLaboratoryId], references: [id])
  results             SurfaceSampleResult[]

  @@unique([surfaceSampleId, surfaceLaboratoryId])
  @@index([surfaceSampleId])
  @@index([surfaceLaboratoryId])
}

model SurfaceSampleResult {
  id                     String               @id @default(uuid())
  surfaceSampleId        String
  surfaceLabAssignmentId String
  elementId              String
  value                  Float?
  unit                   String?
  qualifier              String?
  comments               String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  createdById            Int?
  updatedById            Int?
  sample                 SurfaceSample        @relation(fields: [surfaceSampleId], references: [id])
  assignment             SurfaceLabAssignment @relation(fields: [surfaceLabAssignmentId], references: [id])
  element                Element              @relation(fields: [elementId], references: [id])

  @@unique([surfaceLabAssignmentId, elementId])
  @@index([surfaceSampleId])
  @@index([surfaceLabAssignmentId])
  @@index([elementId])
}

model SurfaceSampleDispatch {
  id                  String                 @id @default(uuid())
  surfaceLaboratoryId String
  projectName         String?
  sentAt              DateTime
  notes               String?
  status              DispatchStatus         @default(PENDING)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  createdById         Int?
  updatedById         Int?
  laboratory          SurfaceLaboratory      @relation(fields: [surfaceLaboratoryId], references: [id])
  createdBy           User?                  @relation("SurfaceDispatchCreatedBy", fields: [createdById], references: [id])
  items               SurfaceDispatchItem[]

  @@index([surfaceLaboratoryId])
  @@index([status])
}

model SurfaceDispatchItem {
  id                String                   @id @default(uuid())
  dispatchId        String
  surfaceSampleId   String
  status            DispatchStatus           @default(PENDING)
  notes             String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  createdById       Int?
  updatedById       Int?
  dispatch          SurfaceSampleDispatch    @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  sample            SurfaceSample            @relation(fields: [surfaceSampleId], references: [id], onDelete: Cascade)
  requestedElements SurfaceDispatchElement[]

  @@unique([dispatchId, surfaceSampleId])
  @@index([dispatchId])
  @@index([surfaceSampleId])
  @@index([status])
}

model SurfaceDispatchElement {
  id             String              @id @default(uuid())
  dispatchItemId String
  elementId      String
  dispatchItem   SurfaceDispatchItem @relation(fields: [dispatchItemId], references: [id], onDelete: Cascade)
  element        Element             @relation(fields: [elementId], references: [id])

  @@unique([dispatchItemId, elementId])
  @@index([dispatchItemId])
  @@index([elementId])
}

